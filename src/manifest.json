{
  "manifest_version": 3,
  "name": "Norish Quick Import",
  "version": "0.1.0",
  "description": "Quickly import recipes to a Norish instance",
  "permissions": ["cookies", "scripting", "activeTab", "webRequest", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  }
}
