  "dependencies": {
    "@heroicons-animated/react": "1.3.0",
    "@heroicons/react": "2.2.0",
    "@heroui/react": "3.0.0-beta.6",
    "@heroui/styles": "3.0.0-beta.6",
    "@trpc/client": "11.10.0",
    "event-source-polyfill": "1.0.31",
    "motion": "12.34.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "superjson": "2.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.2.0",
    "@types/chrome": "0.1.36",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "archiver": "7.0.1",
    "autoprefixer": "10.4.24",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1"
