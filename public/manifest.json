{
  "manifest_version": 3,
  "name": "Norish Quick Import",
  "version": "1.1.0",
  "description": "Quickly import recipes to a Norish instance",
  "permissions": [
    "storage",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
